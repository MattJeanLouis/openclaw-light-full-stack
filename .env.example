# ── Secrets ───────────────────────────────────────────────────────────
# Gateway token for authenticating with OpenClaw
OPENCLAW_GATEWAY_TOKEN=change-me

# Master key for LiteLLM admin API
LITELLM_MASTER_KEY=sk-change-me

# Password for the PostgreSQL database
POSTGRES_PASSWORD=change-me

# ── AI Providers ─────────────────────────────────────────────────────
# At least one provider API key is required
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ── OpenClaw ─────────────────────────────────────────────────────────
# Container image (default: ghcr.io/openclaw/openclaw:latest)
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Network bind mode: lan, loopback, or 0.0.0.0
# OPENCLAW_BIND=lan

# Host port for the gateway
# OPENCLAW_PORT=18789

# ── Postgres ─────────────────────────────────────────────────────────
# POSTGRES_USER=openclaw
# POSTGRES_DB=litellm

# ── Compose Profiles ────────────────────────────────────────────────
# Comma-separated list of profiles to activate:
#   proxy   — Caddy reverse proxy with automatic HTTPS
#   tunnel  — Cloudflare Tunnel for zero-trust access
#   notify  — Diun image update notifications
#   backup  — rclone scheduled backups
COMPOSE_PROFILES=

# ── Profile: tunnel ─────────────────────────────────────────────────
# Required when using the "tunnel" profile
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Profile: proxy ──────────────────────────────────────────────────
# Domain for Caddy automatic HTTPS (default: localhost)
# DOMAIN=example.com
